{
  "name": "@linkedctl/mcp",
  "version": "0.0.0",
  "description": "MCP server for LinkedIn API integration",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "license": "AGPL-3.0-only",
  "author": "Alexey Pelykh (https://github.com/alexey-pelykh)",
  "homepage": "https://github.com/alexey-pelykh/linkedctl/tree/main/packages/mcp",
  "bugs": "https://github.com/alexey-pelykh/linkedctl/issues",
  "funding": "https://github.com/sponsors/alexey-pelykh",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexey-pelykh/linkedctl.git",
    "directory": "packages/mcp"
  },
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./stdio": {
      "types": "./dist/stdio.d.ts",
      "import": "./dist/stdio.js"
    }
  },
  "bin": {
    "linkedctl-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "linkedin",
    "social-media",
    "mcp",
    "model-context-protocol",
    "claude",
    "ai-tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "cp ../../LICENSE .",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@linkedctl/core": "workspace:^",
    "@modelcontextprotocol/sdk": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
