{
  "name": "@linkedctl/core",
  "version": "0.0.0",
  "description": "Core library for LinkedIn API integration",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "license": "AGPL-3.0-only",
  "author": "Alexey Pelykh (https://github.com/alexey-pelykh)",
  "homepage": "https://github.com/alexey-pelykh/linkedctl/tree/main/packages/core",
  "bugs": "https://github.com/alexey-pelykh/linkedctl/issues",
  "funding": "https://github.com/sponsors/alexey-pelykh",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexey-pelykh/linkedctl.git",
    "directory": "packages/core"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "linkedin",
    "linkedin-api",
    "oauth2",
    "social-media",
    "api-client",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "cp ../../LICENSE .",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "docs": "typedoc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typedoc": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
